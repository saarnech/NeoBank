# Copy to .env in the PROJECT ROOT for `docker compose up`. Compose reads these
# to fill the ${...} placeholders in docker-compose.yml. Leave secrets blank.
#
# Running the backend natively instead? Use backend/.env.example, not this file.
# (DATABASE_URL and PORT are omitted here on purpose — docker-compose.yml sets
#  them directly, pointing the backend at the bundled Postgres container.)

JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_TTL_MINUTES=10

# Email (Brevo transactional API)
BREVO_API_KEY=
EMAIL_FROM=NeoBank <your.address@gmail.com>

# LLM (Groq)
GROQ_API_KEY=
