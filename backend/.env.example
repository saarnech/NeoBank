# Copy to backend/.env for local development (the backend loads .env from its
# own directory). Leave secrets blank and fill in your own values.

# ── Database ──────────────────────────────────────────────
# Local Postgres (matches docker-compose) or a Neon connection string.
DATABASE_URL=postgresql://banks_user:banks_password@localhost:5432/banks

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── OTP ───────────────────────────────────────────────────
OTP_TTL_MINUTES=10

# ── Email (Brevo transactional API) ───────────────────────
BREVO_API_KEY=
EMAIL_FROM=NeoBank <your.address@gmail.com>

# ── LLM (Groq) ────────────────────────────────────────────
GROQ_API_KEY=

# ── Server ────────────────────────────────────────────────
PORT=3000
# Production only: the allowed frontend origin for CORS
# (e.g. https://neo-bank-omega.vercel.app). Defaults to http://localhost:5173.
# CORS_ORIGIN=
